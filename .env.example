# Drydock daemon host config. Copy to `.env` (gitignored) and fill in.
# Real environment variables override these; `.env` is for convenience.

# --- Issue tracker (DRY-10) ---
# fixture (default, no creds) | switchyard | jira
DRYDOCK_TRACKER=switchyard
# Switchyard REST API base (no trailing slash, no /v1 — the provider adds it).
# The API listens on :4002; from the host use localhost (the `switchyard`
# hostname only resolves inside the docker network).
DRYDOCK_SWITCHYARD_URL=http://localhost:4002
DRYDOCK_SWITCHYARD_TOKEN=your_token_here
# Jira instead: site base URL + credentials. Cloud = email + API token
# (id.atlassian.com → Security → API tokens); Server/DC = personal access
# token alone, no email.
# DRYDOCK_JIRA_URL=https://yourco.atlassian.net
# DRYDOCK_JIRA_EMAIL=you@yourco.com
# DRYDOCK_JIRA_TOKEN=your_api_token

# --- Ticket-spawn repo mapping (DRY-9) ---
# A ticket's repo name resolves to <root>/<repo> as the spawn cwd.
# DRYDOCK_REPOS_ROOT=~/projects
# Per-repo overrides for repos that live elsewhere (comma-separated name=path):
# DRYDOCK_REPO_PATHS=construct-server=~/construct-server,imperium-loop=~/imperium-loop
# The DRY project has no repo_url, so its tickets resolve to repo "dry":
# DRYDOCK_REPO_PATHS=dry=~/projects/drydock

# --- Worktree isolation (DRY-15) ---
# Ticket-spawned agents in a git repo get their own worktree on branch
# agent/<TICKET>, under this root, so concurrent agents don't clobber each other.
# DRYDOCK_WORKTREES_ROOT=~/.drydock/worktrees
# DRYDOCK_WORKTREES=0            # set 0 to disable — agents run in the repo cwd

# --- Other (optional) ---
# DRYDOCK_HOST=0.0.0.0          # set 127.0.0.1 to lock the daemon to localhost
# DRYDOCK_PORT=4317             # prod (DRY-19) runs 4318 so dev and prod coexist
# DRYDOCK_SHELL=/usr/bin/zsh    # login shell for `+ shell` sessions (defaults to $SHELL)
